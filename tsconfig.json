{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@/*": ["src/*"],
      "~/types": ["src/types.d.ts"]
    },
    "types": ["astro/client"],
    "typeRoots": ["./node_modules/@types", "./src"]
  },
  "include": [".astro/types.d.ts", "src/**/*", "src/**/*.d.ts"],
  "exclude": ["dist/"]
}
