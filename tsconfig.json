{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "allowJs": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@assets/*": ["src/assets/*"],
      "astrowind:config": ["src/generated/astrowind-config.ts"]
    },
    "types": ["astro/client", "vitest/globals"]
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "exclude": ["dist/", "node_modules/"]
}
