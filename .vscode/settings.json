{
  "locale": "de",
  "css.customData": ["./vscode.tailwind.json"],
  "css.lint.unknownAtRules": "ignore",
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "astro",
    "typescript",
    "typescriptreact"
  ],
  "files.associations": {
    "*.mdx": "markdown"
  },
  "prettier.documentSelectors": ["**/*.astro"],
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },
  "yaml.schemas": {
    "./.vscode/astrowind/config-schema.json": "/src/config.yaml"
  },
  "eslint.useFlatConfig": true,
  "terminal.explorerKind": "external",
  "terminal.sourceControlRepositoriesKind": "external",
  "cSpell.words": [
    "Anny",
    "azulverdoso",
    "Azulverdoso",
    "Bildungsakademie",
    "brushbuddy",
    "cimdata",
    "Cimdata",
    "focusbuddy",
    "Focusmate",
    "github",
    "Heilbad",
    "Heiligenstadt",
    "Hochschule",
    "hosten",
    "impressum",
    "Impressum",
    "Innodata",
    "Jüdische",
    "Karls",
    "Kerem",
    "lieferando",
    "Lieferando",
    "linkedin",
    "Linkedin",
    "metacafe",
    "neurodivergent",
    "neurodiverse",
    "neurodiversity",
    "Neurodiversity",
    "omnichannel",
    "photoshoot",
    "Porfolio",
    "Ruprecht",
    "saas",
    "seafoam",
    "Squarespace",
    "Studien",
    "tabler",
    "tailwindcss",
    "tsconfigs",
    "Universität",
    "WBSCS",
    "wireframing",
    "Yair",
    "Yola"
  ],
  "cssvar.files": ["/src/assets/styles/*.css"],
  "cssvar.extensions": [
    "css",
    "scss",
    "sass",
    "less",
    "postcss",
    "astro",
    "vue",
    "svelte",
    "astro",
    "ts",
    "tsx",
    "js",
    "jsx"
  ],
  "cSpell.customDictionaries": {
    "custom-dictionary-workspace": {
      "name": "custom-dictionary-workspace",
      "path": "${workspaceFolder:lylehmann.com}/.cspell/custom-dictionary-workspace.txt",
      "addWords": true,
      "scope": "workspace"
    }
  }
}
