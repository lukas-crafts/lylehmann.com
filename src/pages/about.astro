---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import { Seo } from 'astro-seo-meta';
import { Schema } from 'astro-seo-schema';

const email = import.meta.env.PUBLIC_EMAIL; // Add this line to import the email from the .env.local file
---

<Seo
  title="About - Lukas Yair Lehmann | UX Designer & Accessibility Advocate"
  description="Learn more about Lukas Yair Lehmann, a UX Designer dedicated to creating accessible and inclusive digital experiences. Discover his journey, skills, and passion for user-centered design."
  keywords={["UX Designer", "Accessibility Advocate", "Lukas Yair Lehmann", "User Experience", "Inclusive Design", "Neurodiversity", "Digital Solutions", "Design Portfolio", "UX Design Skills", "UX Design Experience", "Accessibility Expert"]}
  icon="~/assets/favicons/favicon.ico"
  robots='index, follow'
/>

<Schema
  item={{
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: "About me - Lukas Yair Lehmann | UX Designer",
    url: "https://lylehmann.com/about",
    mainEntity: {
      "@id": "https://lylehmann.com/#person",
      name: "Lukas Yair Lehmann",
      jobTitle: "UX Designer",
      url: "https://lylehmann.com",
      sameAs: [
        "https://www.linkedin.com/in/lylehmann/",
        "https://github.com/lylehmann",
      ],
      email: email,
      description: "Lukas Yair Lehmann is a UX Designer with a passion for accessibility and inclusive design. He is a strong advocate for neurodiversity and disability rights, and believes that digital solutions should work for everyone. Lukas has a background in design, accessibility, and disability advocacy, and he is committed to creating digital experiences that are accessible, usable, and enjoyable for all users.",
      knowsAbout: [
        "UX Design",
        "User Experience",
        "Inclusive Design",
        "Neurodiversity",
        "Accessibility",
        "Digital Solutions",
        "Content Strategy",
        "Design Thinking",
        "Web Development",
        "Project Management",
        "Agile Methodologies",
        "Design Thinking",
        "User Research",
        "Prototyping",
        "Usability Testing",
        "Information Architecture",
        "Interaction Design",
      ],
    }
  }}
/>

<Layout>
  <!-- Header Widget ***************** -->
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '/' },
        { text: 'Porfolio', href: '/blog' },
        { text: 'About', href: '/about' },
        { text: 'Resume', href: '/resume' },
      ]}
      actions={[
        {
          text: 'Meet me',
          href: `https://calendly.com/lylehmann`,
          target: '_blank',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Hero Widget ******************* -->

  <Hero>
    <Fragment slot="title"> From Empathy to Innovation <br> <span class="text-4xl font-semibold text-blue-600 dark:text-blue-300">Crafting Inclusive Digital Experiences with Impact</Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-github',
        callToAction: {
          target: '_blank',
          text: 'GitHub',
          href: 'https://github.com/lylehmann',
        },
      },
      {
        icon: 'tabler:brand-linkedin',
        callToAction: {
          target: '_blank',
          text: 'Linkedin',
          href: 'https://www.linkedin.com/in/lylehmann/',
        },
      },
      {
        icon: 'tabler:code',
        callToAction: {
          target: '_blank',
          text: 'WBSCS',
          href: '/',
        },
      },
    ]}
    image={{ src: '~/assets/images/my-journey.jpg', alt: 'A wood, curvy street with cars' }}
    classes={{ container: 'flex flex-col-reverse md:flex-row' }}
  >
    <Fragment slot="content">
      <h2 class="mb-2 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">
        My Journey into UX Design: <br> Empathy, Innovation, and Impact
      </h2>
      <p>
        I started my career in disability support, helping people with special needs. This taught me empathy, clear
        communication, and the value of accessibility-lessons I use in my design work today.
      </p>
      <br />
      <p>
        Later, as a webmaster, I improved websites, organized content, and trained teams. This gave me strong technical
        skills and a focus on creating user-friendly solutions.
      </p>
      <br />
      <p>
        In publishing, I managed projects and teams, building skills in organization and problem-solving. My ADHD
        diagnosis was a turning point. It inspired me to move from publishing to UX design-a field where I can combine
        creativity and problem-solving to make an impact.
      </p>
      <br />
      <p>
        Now, I combine my diverse experiences with UX/UI design training to create accessible and user-friendly digital
        solutions that truly work for everyone.
      </p>
      <br />
      <p>Curious to learn more? Let's connect!</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 gap-1 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>
