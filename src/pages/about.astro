---
import Layout from "~/layouts/PageLayout.astro";

import Header from "~/components/widgets/Header.astro";
import Hero from "~/components/widgets/Hero.astro";
import Content from "~/components/widgets/Content.astro";
import { Seo } from "astro-seo-meta";
import { Schema } from "astro-seo-schema";

import myJourney from "~/assets/images/my-journey.jpg";
---

<Seo
  title="About - Lukas Yair Lehmann | UX Designer & Accessibility Advocate"
  description="Learn about Lukas Yair Lehmann, a UX designer creating accessible, inclusive experiences. Explore his journey, skills, and passion for user-first design."
  keywords={["UX Designer", "Accessibility Advocate", "Lukas Yair Lehmann", "User Experience", "Inclusive Design", "Neurodiversity", "Digital Solutions", "Design Portfolio", "UX Design Skills", "UX Design Experience"]}
  icon="~/assets/favicons/favicon.ico"
  robots='index, follow'
  facebook={{
    image: "~/assets/images/hero-image.jpeg", // Replace with a default image path
    url: "https://lylehmann.com/about",
    type: "website",
  }}
  twitter={{
    image: "~/assets/images/hero-image.jpeg", // Replace with a default image path
    site: "@lylehmann",
    card: "summary_large_image",
  }}
/>

<Schema
  item={{
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "dateCreated": "2025-15-01",
    "dateModified": "2025-01-29",
    "mainEntity": {
      "@type": "Person",
      "name": "Lukas Yair Lehmann",
      "alternateName": "Lukas Lehmann",
      "identifier": "lylehmann",
      "description": "UX Designer and Accessibility Advocate",
      "image": "https://lylehmann.com/assets/images/hero-image.jpeg",
      "sameAs": [
        "https://www.linkedin.com/in/lylehmann/",
        "https://github.com/lylehmann",
      ],
    }
  }}
/>

<Schema
  item={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://lylehmann.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "About",
        item: "https://lylehmann.com/about",
      },
    ],
  }}
/>

<Layout>
  <!-- Header Widget ***************** -->
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '/' },
        { text: 'Porfolio', href: '/portfolio' },
        { text: 'About', href: '/about' },
        { text: 'Resume', href: '/resume' },
      ]}
      actions={[
        {
          text: 'Meet me',
          href: `https://calendly.com/lylehmann`,
          target: '_blank',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Hero Widget ******************* -->

  <Hero>
    <Fragment slot="title"> From Empathy to Innovation <br> <span class="text-4xl font-semibold">Crafting Inclusive Digital Experiences with Impact</span></Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-github',
        callToAction: {
          target: '_blank',
          text: 'GitHub',
          href: 'https://github.com/lylehmann',
        },
      },
      {
        icon: 'tabler:brand-linkedin',
        callToAction: {
          target: '_blank',
          text: 'Linkedin',
          href: 'https://www.linkedin.com/in/lylehmann/',
        },
      },
      {
        icon: 'tabler:code',
        callToAction: {
          target: '_blank',
          text: 'WBSCS',
          href: '/',
        },
      },
    ]}
    image={{ src: myJourney, alt: 'A wood, curvy street with cars' }}
    classes={{ container: 'flex flex-col-reverse md:flex-row' }}
  >
    <Fragment slot="content">
      <h2 class="mb-2 text-2xl font-bold tracking-tight sm:text-3xl">
        My Journey into UX Design: <br> Empathy, Innovation, and Impact
      </h2>
      <p>
        I started my career in disability support, helping people with special needs. This taught me empathy, clear
        communication, and the value of accessibility-lessons I use in my design work today.
      </p>
      <br />
      <p>
        Later, as a webmaster, I improved websites, organized content, and trained teams. This gave me strong technical
        skills and a focus on creating user-friendly solutions.
      </p>
      <br />
      <p>
        In publishing, I managed projects and teams, building skills in organization and problem-solving. My ADHD
        diagnosis was a turning point. It inspired me to move from publishing to UX design-a field where I can combine
        creativity and problem-solving to make an impact.
      </p>
      <br />
      <p>
        Now, I combine my diverse experiences with UX/UI design training to create accessible and user-friendly digital
        solutions that truly work for everyone.
      </p>
      <br />
      <p>Curious to learn more? Let's connect!</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 gap-1 bg-custom-light dark:bg-custom-dark"></div>
    </Fragment>
  </Content>
