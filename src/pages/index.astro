---
import { getCollection } from 'astro:content';
import Headline from "../components/ui/Headline.astro";
import ItemGrid2 from "../components/ui/ItemGrid2.astro";
import CallToAction from "../components/widgets/CallToAction.astro";
import Header from "../components/widgets/Header.astro";
import Hero2 from "../components/widgets/Hero2.astro";
import Layout from "../layouts/PageLayout.astro";

const allProjects = await getCollection('projects');
const selectedIds = ["focusbuddy-case-study", "brushbuddy-case-study", "mettacafe-case-study"];
const projects = allProjects.filter(p => selectedIds.includes(p.id));

const skills = [
  { icon: "tabler:layout-dashboard", title: "UX & Product", description: "I make websites and apps easy to use." },
  { icon: "tabler:code", title: "Frontend", description: "I build websites that look good and work fast." },
  { icon: "tabler:robot", title: "AI & Automation", description: "I add smart features that help you get things done." },
  { icon: "tabler:accessible", title: "Accessibility", description: "I make sure everyone can use what I build." },
];
---

<Layout metadata={{ title: 'Home' }}>
  <Fragment slot="header">
    <Header
      links={[{ text: 'Home', href: '/' }, { text: 'Portfolio', href: '/portfolio' }, { text: 'About', href: '/about' }]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <Hero2
    title="Designing for Humans. Building for the Web."
    subtitle="I turn complex challenges into digital products people love to use."
    actions={[{ variant: 'solid', text: "Let's Work Together", href: 'mailto:lylehmann@gmail.com', icon: 'tabler:mail' }]}
    image={{ src: '/assets/images/lylehmann.png', alt: 'Lukas Lehmann' }}
  />

  <section class="mx-auto mt-40 mb-20 px-4 max-w-5xl">
    <Headline title="What I Do" />
    <ItemGrid2 items={skills} columns={4} />
  </section>

  <section class="mx-auto mb-20 px-4 max-w-6xl">
    <Headline title="Selected Projects" />
    <div class="gap-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <div class="flex flex-col justify-between bg-[var(--color-bg-subtle)] p-8 border border-[var(--color-border-default)] rounded-2xl
       transition-all hover:scale-[1.03]">
          {project.data.cover && <img src={project.data.cover} alt={project.data.title} class="mb-6 rounded-xl w-full h-48 object-cover"
       />}
          <div>
            <h3 class="mb-2 font-bold text-white text-xl">{project.data.title}</h3>
            <p class="mb-4 text-sm">{project.data.description ?? project.data.excerpt}</p>
          </div>
          <a href={`/portfolio/${project.id}`} class="font-semibold text-primary hover:underline">View Case Study</a>
        </div>
      ))}
    </div>
  </section>

  <CallToAction title="Ready to ship?" subtitle="Let's talk." />
</Layout>
