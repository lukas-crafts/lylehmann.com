<!-- trunk-ignore-all(biome) -->
---
import ContentMedia from "@components/ContentMedia.astro";
import ExternalLink from "@components/ExternalLink.astro";
import Feature from "@components/Feature.astro";
import Hero from "@components/Hero.astro";
import DefaultLayout from "@layouts/DefaultLayout.astro";
import { Icon } from "astro-icon/components";
import { Badge } from "accessible-astro-components";
import SentryTest from "@components/SentryTest.astro";
---

<DefaultLayout title="Home">
	<SentryTest />
	<Hero />
	<section class="my-64">
		<div class="container">
			<h2 class="mb-16 text-6xl">About Me</h2>
			<div class="mb-8">
				<p class="text-2xl">
					I'm Lukas Yair Lehmann, a Berlin-based creative technologist with deep experience in web management, UX
					design, and digital publishing. My work spans frontend development, CMS architecture, and UX/UI - always
					grounded in accessibility, clarity, and thoughtful design.
				</p>
			</div>
			<div class="space-content">
				<p class="text-2xl">Previously, I've worked as a:</p>
				<ul class="pl-6 mb-6 space-y-2 text-2xl list-disc list-outside">
					<li>
						<strong>Webmaster</strong> at the <ExternalLink href="https://www.hfjs.eu"
							>Hochschule f&uumlr J&uuml;dische Studien Heidelberg</ExternalLink
						> where I implemented content into a static website using HTML, CSS, and JavaScript, ensuring a user-friendly
						experience for students and faculty.
					</li>
					<li>
						<strong>Website & Database Manager</strong> at <ExternalLink href="https://leobaeck.org/"
							>Leo Baeck Institute Jerusalem</ExternalLink
						>, where I redesigned the website and optimized the database for better performance.
					</li>
					<li>
						<strong>Production Specialist</strong> at academic publishers like <ExternalLink
							href="https://www.degruyterbrill.com/">De Gruyter</ExternalLink
						> and <ExternalLink href="https://innodata.com/">Innodata</ExternalLink>, where I coordinated the production
						of Books and Journals from manuscript handover to final publication, ensuring high-quality standards and
						adherence to deadlines.
					</li>
				</ul>
			</div>
			<br>
			<div class="space-content">
				<p class="text-2xl">
					I've collaborated with academic institutions, cultural organizations, and cross-functional teams to plan, build, and maintain digital ecosystems. I care deeply about inclusive design, semantic HTML, clean CSS, and meaningful content structures.
				</p>
			</div>
			</div>
			</section>
			<div class="container">
				<h3 class="mb-16 text-6xl">Tools & Skills:</h3>
			<div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
				<Feature icon="lucide:app-window" title="Product & UX design">
					Figma, Sketch, Adobe XD, UI/UX Design, Wireframing, Prototyping, Design Systems, Responsive Design
				</Feature>

				<Feature icon="lucide:users" title="User research & testing">
					User Interviews, Usability Testing, Personas, User Journeys, A/B Testing, Information Architecture
				</Feature>

				<Feature icon="lucide:code" title="Frontend development">
					HTML5, CSS3, AstroJS, WordPress, TYPO3, Responsive Coding, Git, Vercel
				</Feature>

				<Feature	 icon="lucide:layout" title="Design systems & branding">
					Design Systems, Style Guides, Brand Identity, Visual Design, Typography, Color Theory
				</Feature>

				<Feature icon="lucide:funnel" title="Strategy & business">
					Market Research, Brand Guidelines, SEO Optimization, Content Strategy, User Analytics, Conversion Optimization
				</Feature>

				<Feature icon="lucide:heart-handshake" title="Collaboration & delivery">
					Agile, Scrum, Design Thinking, Design Sprint, Jira, Miro, Cross-functional Teamwork
				</Feature>

				<Feature icon="lucide:globe" title="Languages:"> German (Native), English (C2), Hebrew (B2). </Feature>
			</div>
		</div>
	</section>
		<ContentMedia imgSrc="/wcag-compliant.webp" reverseImg={true}>
		<h2>Metta Café</h2>
<div class="flex flex-wrap gap-2">
  <Badge>UX/UI Design</Badge>
  <Badge>Website</Badge>
  <Badge>Mobile App</Badge>
  <Badge>Group Project</Badge>
	<Badge>E-Commerce</Badge>
</div>
		<p class="text-2xl">
			A modern, accessible website and app for a café-bakery-yoga venue.
I focused on the homepage and food ordering experience, helping translate its unique atmosphere into a seamless online presence that increases engagement and drives sales.
		<div class="flex min-[500px]:flex-row flex-col gap-3">
			<a class="button has-icon color-secondary" href="/portfolio">
				<Icon name="lucide:arrow-right" />
					View Case Study
			</a>
		</div>
	</ContentMedia>
	<ContentMedia imgSrc="/accessible-components.webp">
		<h2>FocusBuddy</h2>
		<div class="flex flex-wrap gap-2 mb-4 text-sm">
			<Badge>UX/UI Design</Badge>
			<Badge>macOS App</Badge>
			<Badge>Accessibility</Badge>
			<Badge>Neurodiversity</Badge>
			<Badge>Solo Project</Badge>
		</div>
		<p class="mb-4 text-2xl">
    A macOS app concept to support focus and accountability - designed for people with ADHD, remote workers, and students. FocusBuddy offers a distraction-free interface that helps users stay on task and feel supported.
  </p>
		<div class="flex min-[500px]:flex-row flex-col gap-3">
      <a class="button has-icon color-secondary" href="/portfolio">
        <Icon name="lucide:arrow-right" />
          View Case Study
      </a>
    </div>
	</ContentMedia>
	<ContentMedia imgSrc="/wcag-compliant.webp" reverseImg={true}>
		<h2>BrushBuddy</h2>
		<div class="flex flex-wrap gap-2 mb-4 text-sm">
    <Badge>UX/UI Design</Badge>
    <Badge>Mobile App</Badge>
		<Badge>Accessibility</Badge>
    <Badge>Neurodiversity</Badge>
		<Badge>Solo Project</Badge>
  </div>
		<p class="mb-4 text-2xl">
			A mobile app concept that makes oral care routines more engaging - designed to support neurodivergent individuals through music, structured routines, and accessible design.
		<div class="flex min-[500px]:flex-row flex-col gap-3">
			<a class="button has-icon color-secondary" href="/portfolio">
				<Icon name="lucide:arrow-right" />
					View Case Study
			</a>
		</div>
	</ContentMedia>
</DefaultLayout>

<style>
	.avatar {
		border: 1px solid var(--border-color-subtle);
		border-radius: var(--radius-md);
		padding: var(--space-s);
	}
</style>
