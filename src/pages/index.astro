---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const email = import.meta.env.PUBLIC_EMAIL; // Add this line to import the email from the .env.local file

const metadata = {
  title: 'Inclusive UX Designer | Accessibility - Lukas Yair Lehmann',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Header Widget ***************** -->
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '/'},
        { text: 'Porfolio', href: '/blog' },
        { text: 'About', href: '/about' },
        { text: 'Resume', href: '/resume' },
      ]}
      actions={[
        {
          text: 'Meet me',
          href: `https://calendly.com/lylehmann`,
          target: '_blank',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Explore My Portfolio',
        href: '/blog',
      },
      { text: 'Learn About Me', href: '/about' },
    ]}
    image={{ src: '~/assets/images/hero-image.jpeg', alt: 'Lukas Lehmann', width: 800, height: 800 }}
  >
    <Fragment slot="title"> Hi, I'm Lukas 👋 <br> <span class="text-4xl font-semibold text-blue-600 dark:text-blue-300">Inclusive UX Designer Creating Accessible Digital Experiences</span></Fragment>

    <Fragment slot="subtitle">
      I specialize in designing inclusive and user-friendly solutions, with a focus on accessibility and neurodiversity.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="value"
    columns={1}
    items={[
      {
        icon: 'tabler:empathize',
        description: '<span class="font-semibold">Empathy-driven Design</span>'
      },
      {
        icon: 'tabler:accessible',
        description:'<span class="font-semibold">Accessibility Advocacy</span>',
      },
      {
        icon: 'tabler:ux-circle',
        description: '<span class="font-semibold">User-Centered Problem Solving</span>',
      },
    ]}
    image={{ src: '~/assets/images/inclusive-design.png', alt: 'People Having a Meeting at the Office' }}
    classes={{ container: 'flex flex-col-reverse md:flex-row' }}
  >
    <Fragment slot="content">
      <h2 class="mb-2 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">
        Designing for Inclusion, Innovation, and Impact
      </h2>

      <p>
        With a background in disability work, website and project coordination as well as in UX design, I create digital solutions that are not only functional but also truly accessible. My mission is to ensure that every user - regardless of ability or neurodiversity - feels empowered and supported when interacting with technology.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 gap-1 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    id="portfolio"
    title="Explore My Work"
    isReversed
    items={[
      {
        title: 'Description:',
        description:
          'Designed FocusBuddy, a macOS app aimed at helping individuals, particularly those with ADHD or productivity challenges, stay focused and accountable during work sessions. The app features tools like a Pomodoro timer, focus-enhancing music, and a collaborative space to connect with accountability partners.',
      },
      {
        title: 'Role:',
        description:
          'Led the end-to-end design process, including user research, ideation, prototyping, and testing. Focused on creating a clean, user-friendly interface tailored to the needs of neurodivergent users.',
      },
    ]}
    image={{
      src: '~/assets/images/FocusBuddy.png',
      alt: 'Tech Design Image',
    }}
    callToAction={{
      text: 'View Case Study',
      icon: 'tabler:chevron-right',
      href: '/focusbuddy-case-study',
    }}
  >
    <Fragment slot="content">
      <h3 class="mb-2 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">
        Project 1: <br /><span class="text-2xl">FocusBuddy: Boosting Focus and Accountability</span>
      </h3>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Description:',
        description:
          'Developed BrushingBuddy, a mobile app aimed at supporting users in building better oral hygiene routines. The app uses gamification and music integration to make brushing more engaging while catering to neurodivergent users with a simple, distraction-free design.',
      },
      {
        title: 'Role:',
        description: `Led the end-to-end product design process, including user research, ideation, prototyping, and usability testing. Designed a minimalist, user-friendly interface to reduce cognitive load and increase routine adherence.`,
      },
    ]}
    image={{
      src: '~/assets/images/BrushingBuddy.png',
      alt: 'Art and Music Poster Image',
    }}
    callToAction={{
      text: 'View Case Study',
      icon: 'tabler:chevron-right',
      href: '/brushbuddy-case-study',
    }}
  >
    <Fragment slot="content">
      <h3 class="mb-2 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">
        Project 2: <br /><span class="text-2xl">BrushingBuddy: Simplifying Oral Care Routines</span>
      </h3>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Description:',
        description: `Designed a website and mobile app for Das Metta, a Munich-based cafe, bakery, and yoga space. The goal was to improve online visibility, highlight unique offerings like gluten-free and vegan products, and provide a seamless booking system for yoga classes.`,
      },
      {
        title: 'Role:',
        description: `Created UX designs for the homepage, online store, and mobile app. Focused on responsive layouts, clear navigation, and mobile-first features to enhance usability for diverse customers.`,
      },
    ]}
    image={{
      src: '~/assets/images/Metta.png',
      alt: 'Fashion e-commerce Image',
    }}
    callToAction={{
      text: 'View Case Study',
      icon: 'tabler:chevron-right',
      href: '/metacafe-case-study',
    }}
  >
    <Fragment slot="content">
      <h3 class="mb-2 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">
        Project 3: <br /><span class="text-2xl">Das Metta: Redesigning a Cafe & Yoga Space</span>
      </h3>
    </Fragment>
  </Content>

  <!-- About Me Widget **************** -->
  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={1}
    items={[
      {
        callToAction: {
          text: 'Learn More About Me ',
          icon: 'tabler:chevron-right',
          href: '/about',
        },
      },
    ]}
    image={{ src: '~/assets/images/my-journey.jpg', alt: 'Wood, curvy street with cars' }}
    classes={{ container: 'flex flex-col-reverse md:flex-row' }}
  >
    <Fragment slot="content">
      <h2 class="mb-2 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">
        From Empathy to Innovation: <br> My Journey into UX Design
      </h2>

      <p>
        I started my career in disability work, where I learned the importance of empathy and accessibility. From there, I transitioned into UX design, combining my diverse experiences with technical skills to create meaningful digital solutions. Curious about my story?
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 gap-1 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features3 Widget ************** -->

  <Features3
    title="Skills That Bring Ideas to Life"
    subtitle="With a strong foundation in UX product design, accessibility, and design tools, I bridge creativity and functionality to deliver impactful solutions. <br> <br> Here is how I can help your project succeed:"
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'Design Tools',
        description:
          'Figma, Adobe XD, Sketch',
      },
      {
        title: 'Web Development Skills',
        description:
          'HTML, CSS, WordPress',
      },
      {
        title: 'Methodologies',
        description:
          'Agile, Scrum, Design Thinking, Service Design',
      },
      {
        title: 'Specialties',
        description:
          'Accessibility, Inclusive UX/UI, User-Centered Design',
      },
      {
        title: 'Research',
        description:
          'User Research, Usability Testing, A/B Testing',
      },
      {
        title: 'Project Management',
        description:
          'Jira, Trello, Asana, Microsoft Project',
      },
      {
        title: 'Analytics',
        description:
          'Google Analytics, Microsoft Clarity',
      },
      {
        title: 'Design Systems',
        description:
          'Creating and maintaining design systems',
      },
      {
        title: 'Collaboration',
        description:
          'Cross-functional teamwork, stakeholder management',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    id="contact"
    actions={[
      {
        variant: 'primary',
        text: 'Find Me on LinkedIn',
        href: 'https://www.linkedin.com/in/lylehmann/',
        target: '_blank',
      },
      {
        variant: 'secondary',
        text: 'Email Me',
        href: `mailto:${email}`, // Update this line to use the imported email
      },
    ]}
  >
    <Fragment slot="title"> Let's Build Something Amazing Together</Fragment>

    <Fragment slot="subtitle">
      I'm excited to work on meaningful projects. If you need an inclusive UX designer or a creative partner, let's connect and make something great.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 gap-1 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </CallToAction>
</Layout>
