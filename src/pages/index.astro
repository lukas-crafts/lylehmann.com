---
import { MoveRight } from "lucide-astro";
import Footer from "~/components/widgets/Footer.astro";
import GitHubStatus from "~/components/widgets/GitHubStatus.astro";
import Header from "~/components/widgets/Header.astro";
import LatestUpdate from "~/components/widgets/LatestUpdate.astro";
import Layout from "~/layouts/Layout.astro";
---

<Layout 
  title="Lukas Yair Lehmann | UX Designer & Accessibility Engineer"
  description="Designing and engineering inclusive digital experiences that empower every user. Specialist in WCAG, Astro, and Tailwind CSS."
>
  <Header slot="header" />

  <section class="min-h-screen flex flex-col px-6 pt-20 pb-16 sm:px-12 lg:px-20">
    <div class="my-auto max-w-3xl lg:max-w-4xl w-full mx-auto space-y-12">
      <header class="space-y-6">
        <div class="flex flex-wrap items-center gap-3">
          <div class="inline-block px-4 py-1.5 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-xs font-bold tracking-wider uppercase text-emerald-400 animate-pulse">
            Bespoke Astro 6 + Tailwind 4
          </div>
          <LatestUpdate server:defer>
            <div slot="fallback" class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900 border border-zinc-800 text-zinc-500 text-xs font-bold">
              <div class="w-2 h-2 rounded-full bg-zinc-800 animate-pulse"></div>
              Loading status...
            </div>
          </LatestUpdate>
          <GitHubStatus server:defer>
            <div slot="fallback" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-900 border border-zinc-800 text-zinc-600 text-xs animate-pulse">
              <div class="w-3 h-3 rounded-full bg-zinc-800"></div>
              <div class="h-3 w-24 bg-zinc-800 rounded"></div>
            </div>
          </GitHubStatus>
        </div>

        <h1 class="text-6xl font-black tracking-tight sm:text-8xl bg-linear-to-br from-white via-white to-zinc-600 bg-clip-text text-transparent leading-[1.1]">
          Digital Inclusivity <br /> <span class="text-emerald-500">by Design.</span>
        </h1>
        <p class="text-xl text-zinc-400 leading-relaxed max-w-xl">
          Building the future of accessible UX. Currently migrating to a high-performance, bespoke architecture focused on radical user empowerment.
        </p>
      </header>
      
      <div class="flex flex-wrap gap-5">
        <a href="mailto:lylehmann@gmail.com" class="group flex items-center gap-3 px-8 py-4 rounded-2xl bg-zinc-50 text-zinc-950 font-bold transition-all hover:bg-white hover:ring-8 hover:ring-zinc-50/5 active:scale-95">
          Get in touch
          <MoveRight class="w-5 h-5 transition-transform group-hover:translate-x-1" />
        </a>
        <a href="/portfolio" class="px-8 py-4 rounded-2xl border border-zinc-800 bg-zinc-900/50 font-bold text-zinc-300 hover:bg-zinc-800 transition-all active:scale-95">
          View Portfolio
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
