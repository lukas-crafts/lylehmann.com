---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import ProjectCard from '~/components/portfolio/ProjectCard.astro';

const projects = await getCollection('portfolio', ({ data }) => {
  return data.draft !== true;
});

// Sort by date descending
projects.sort((a, b) => {
  const dateA = new Date(a.data.publishDate).getTime();
  const dateB = new Date(b.data.publishDate).getTime();
  return dateB - dateA;
});
---

<Layout title="Portfolio | Lukas Yair Lehmann" description="Selected works in UX design, accessible engineering, and digital inclusivity.">
  <Header slot="header" />

  <section class="min-h-screen p-6 pt-32 pb-20">
    <main class="max-w-6xl mx-auto space-y-16">
      <header class="max-w-3xl space-y-6">
        <div class="inline-block px-4 py-1.5 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-xs font-bold tracking-wider uppercase text-emerald-400">
          Case Studies
        </div>
        <h1 class="text-5xl font-black tracking-tight sm:text-7xl bg-linear-to-br from-white via-white to-zinc-600 bg-clip-text text-transparent leading-tight">
          Selected <span class="text-emerald-500">Works.</span>
        </h1>
        <p class="text-xl text-zinc-400 leading-relaxed">
          Exploring the intersection of human-centric design and technical excellence. Each project is a deep dive into accessibility and performance.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map(project => (
          <ProjectCard project={project} />
        ))}
      </div>
    </main>
  </section>

  <Footer slot="footer" />
</Layout>
