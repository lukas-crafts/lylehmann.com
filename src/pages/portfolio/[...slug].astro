---
export const prerender = true;

import { Picture } from "astro:assets";
import { getCollection, render } from "astro:content";
import type { ImageMetadata } from "astro";
import {
  DesignElementList,
  FaqList,
  FeatureList,
  InsightList,
  OutcomeList,
  Stats,
  StepList,
} from "~/components/mdx/case-study-blocks";
import CaseStudyLayout from "~/layouts/CaseStudyLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("portfolio", ({ data }) => {
    return import.meta.env.DEV || !data.draft;
  });
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;

if (!project) {
  return Astro.redirect("/404");
}

const {
  title,
  description,
  date,
  image,
  imageAlt,
  tags = [],
  metadata = {},
  role,
  team,
  duration,
  tools = [],
} = project.data;

const { Content, headings, remarkPluginFrontmatter } = await render(project);
const projectImage = image as ImageMetadata | undefined;
const readingTime = remarkPluginFrontmatter?.readingTime;

const components = {
  Stats,
  FeatureList,
  StepList,
  DesignElementList,
  OutcomeList,
  InsightList,
  FaqList,
  img: Picture,
};
---

<CaseStudyLayout
  title={title}
  description={description}
  date={date}
  image={projectImage}
  imageAlt={imageAlt}
  tags={tags}
  role={role}
  team={team}
  duration={duration}
  readingTime={readingTime}
  tools={tools}
  headings={headings}
  projectId={project.id}
  metadata={metadata}
>
  <Content components={components} />
</CaseStudyLayout>
