---
import {
  MessageSquare,
  MoveRight,
  PencilRuler,
  Rocket,
  Search,
  ShieldCheck,
  Smartphone,
} from "lucide-astro";
import Footer from "~/components/widgets/Footer.astro";
import Header from "~/components/widgets/Header.astro";
import Layout from "~/layouts/Layout.astro";

const services = [
  {
    title: "UX/UI Design",
    description:
      "Crafting intuitive, beautiful, and accessible interfaces that users love to interact with.",
    icon: PencilRuler,
  },
  {
    title: "Accessibility Audits",
    description:
      "Ensuring your digital products meet WCAG 2.2 standards for maximum inclusivity.",
    icon: ShieldCheck,
  },
  {
    title: "Frontend Development",
    description:
      "Building high-performance, responsive websites using Astro, React, and modern CSS.",
    icon: Rocket,
  },
  {
    title: "UX Research",
    description:
      "Deep diving into user behavior to inform design decisions with real data.",
    icon: Search,
  },
  {
    title: "Mobile App Design",
    description:
      "Modern mobile experiences optimized for both iOS and Android platforms.",
    icon: Smartphone,
  },
  {
    title: "Conversational UX",
    description:
      "Designing AI and chatbot interfaces that feel human and helpful.",
    icon: MessageSquare,
  },
];
---

<Layout title="Services | Lukas Yair Lehmann" description="Professional UX design and accessible development services.">
  <Header slot="header" />

  <section class="min-h-screen p-6 pt-32 pb-20">
    <main class="max-w-6xl mx-auto space-y-24">
      <header class="max-w-3xl space-y-6">
        <div class="inline-block px-4 py-1.5 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-xs font-bold tracking-wider uppercase text-emerald-400">
          How I Can Help
        </div>
        <h1 class="text-6xl font-black tracking-tight sm:text-7xl bg-gradient-to-br from-white via-white to-zinc-600 bg-clip-text text-transparent leading-tight">
          Services to <span class="text-emerald-500">Empower.</span>
        </h1>
        <p class="text-xl text-zinc-400 leading-relaxed max-w-xl">
          I provide end-to-end design and development solutions focused on performance, accessibility, and user delight.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(service => (
          <div class="p-8 rounded-3xl border border-zinc-800 bg-zinc-900/50 hover:border-emerald-500/30 transition-all hover:-translate-y-1 group">
            <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 mb-8">
              <service.icon class="w-6 h-6" />
            </div>
            <div class="space-y-4">
              <h3 class="text-2xl font-bold text-white group-hover:text-emerald-400 transition-colors">{service.title}</h3>
              <p class="text-zinc-400 leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="p-12 rounded-[2.5rem] bg-gradient-to-br from-emerald-500 to-emerald-700 text-zinc-950 flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="space-y-4">
          <h2 class="text-4xl font-black tracking-tight">Ready to build something inclusive?</h2>
          <p class="text-emerald-950/80 font-medium text-lg max-w-md">Let's collaborate on your next project and set a new standard for digital accessibility.</p>
        </div>
        <a href="/contact" class="px-8 py-4 rounded-2xl bg-zinc-950 text-white font-bold transition-all hover:scale-105 active:scale-95 flex items-center gap-2 shrink-0">
          Get in touch <MoveRight class="w-5 h-5" />
        </a>
      </div>
    </main>
  </section>

  <Footer slot="footer" />
</Layout>
