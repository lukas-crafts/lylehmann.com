---
import { Linkedin, Mail } from "lucide-astro";
import Footer from "~/components/widgets/Footer.astro";
import Header from "~/components/widgets/Header.astro";
import Layout from "~/layouts/Layout.astro";

const social = [
  {
    name: "Email",
    handle: "lylehmann@gmail.com",
    href: "mailto:lylehmann@gmail.com",
    icon: Mail,
  },
  {
    name: "LinkedIn",
    handle: "Lukas Yair Lehmann",
    href: "https://linkedin.com/in/lylehmann",
    icon: Linkedin,
  },
];
---

<Layout title="Contact | Lukas Yair Lehmann" description="Get in touch to discuss your next project or just say hello.">
  <Header slot="header" />

  <section class="min-h-screen p-6 pt-32 pb-20">
    <main class="max-w-6xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-24">
        <div class="flex-1 space-y-12">
          <header class="space-y-6">
            <div class="inline-block px-4 py-1.5 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-xs font-bold tracking-wider uppercase text-emerald-400">
              Connections
            </div>
            <h1 class="text-6xl font-black tracking-tight sm:text-7xl bg-linear-to-br from-white via-white to-zinc-600 bg-clip-text text-transparent leading-tight">
              Let's <span class="text-emerald-500">Talk.</span>
            </h1>
            <p class="text-xl text-zinc-400 leading-relaxed max-w-xl">
              Have a project in mind or just want to discuss the future of accessible design? I'd love to hear from you.
            </p>
          </header>

          <div class="space-y-6">
            {social.map(item => (
              <a href={item.href} class="flex items-center gap-6 p-6 rounded-3xl border border-zinc-800 bg-zinc-900/50 hover:bg-zinc-900 hover:border-emerald-500/30 transition-all group">
                <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 group-hover:scale-110 transition-transform">
                  <item.icon class="w-6 h-6" />
                </div>
                <div class="space-y-1">
                  <div class="text-zinc-500 text-sm font-bold uppercase tracking-widest">{item.name}</div>
                  <div class="text-xl font-bold text-white group-hover:text-emerald-400 transition-colors">{item.handle}</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="flex-1">
          <form 
            id="contact-form"
            class="p-10 rounded-[2.5rem] border border-zinc-800 bg-zinc-900/30 space-y-8"
          >
            <div id="form-feedback" class="hidden p-4 rounded-xl text-sm font-bold"></div>
            
            <div class="space-y-6">
              <div class="space-y-2">
                <label for="name" class="text-sm font-bold text-zinc-400 ml-1">Your Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  class="w-full px-6 py-4 rounded-2xl bg-zinc-950 border border-zinc-800 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all placeholder:text-zinc-700"
                  placeholder="John Doe"
                />
              </div>
              <div class="space-y-2">
                <label for="email" class="text-sm font-bold text-zinc-400 ml-1">Email Address</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  class="w-full px-6 py-4 rounded-2xl bg-zinc-950 border border-zinc-800 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all placeholder:text-zinc-700"
                  placeholder="john@example.com"
                />
              </div>
              <div class="space-y-2">
                <label for="message" class="text-sm font-bold text-zinc-400 ml-1">Message</label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="5"
                  required
                  class="w-full px-6 py-4 rounded-2xl bg-zinc-950 border border-zinc-800 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all placeholder:text-zinc-700 resize-none"
                  placeholder="Tell me about your project..."
                ></textarea>
              </div>
            </div>
            <button type="submit" id="submit-btn" class="w-full py-5 rounded-2xl bg-emerald-500 text-white font-black text-lg transition-all hover:scale-[1.02] active:scale-[0.98] hover:shadow-[0_0_30px_rgba(16,185,129,0.3)] disabled:opacity-50 disabled:cursor-not-allowed">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </main>
  </section>

  <script>
    import { actions } from "astro:actions";

    const form = document.getElementById('contact-form') as HTMLFormElement;
    const feedback = document.getElementById('form-feedback');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      submitBtn.disabled = true;
      submitBtn.innerText = "Sending...";

      try {
        const { data, error } = await actions.contact(formData);

        if (error) {
          if (feedback) {
            feedback.innerText = error.message || "An error occurred. Please try again.";
            feedback.className = "p-4 rounded-xl text-sm font-bold bg-red-500/10 text-red-400 border border-red-500/20 mb-6";
            feedback.classList.remove('hidden');
          }
        } else if (data?.success) {
          if (feedback) {
            feedback.innerText = data.message;
            feedback.className = "p-4 rounded-xl text-sm font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 mb-6";
            feedback.classList.remove('hidden');
          }
          form.reset();
        }
      } catch (err) {
        if (feedback) {
          feedback.innerText = "Something went wrong. Please check your connection.";
          feedback.className = "p-4 rounded-xl text-sm font-bold bg-red-500/10 text-red-400 border border-red-500/20 mb-6";
          feedback.classList.remove('hidden');
        }
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerText = "Send Message";
      }
    });
  </script>

  <Footer slot="footer" />
</Layout>
