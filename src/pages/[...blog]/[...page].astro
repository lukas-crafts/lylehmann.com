---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';
import Header from '~/components/widgets/Header.astro';
import { Seo } from 'astro-seo-meta';
import { Schema } from 'astro-seo-schema';
// import PostTags from "~/components/blog/Tags.astro";

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';

const email = import.meta.env.PUBLIC_EMAIL; // Add this line to import the email from the .env.local file

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

// const allCategories = await findCategories();
// const allTags = await findTags();

---

<Seo
  title="Portfolio - Lukas Yair Lehmann | UX Designer & Accessibility"
  description="Discover UX design, accessibility, and digital innovation insights on Lukas Yair Lehmann's blog. Explore case studies, solutions, and process."
  keywords={["UX Design", "Accessibility", "Inclusive Design", "Digital Innovation", "User Experience", "Design Process", "Case Studies", "Creative Solutions", "Design Portfolio", "UX Design Skills", "UX Design Experience"]}
  icon="~/assets/favicons/favicon.ico"
  robots={blogListRobots}
/>

<Schema
  item={{
    "@context": "https://schema.org",
    "@type": "Blog",
    name: "Portfolio - Lukas Yair Lehmann | UX Designer",
    url: "https://lylehmann.com/blog",
    mainEntity: {
      "@type": "Person",
      "@id": "https://lylehmann.com/#person",
      name: "Lukas Yair Lehmann",
      jobTitle: "UX Designer",
      url: "https://lylehmann.com",
      sameAs: [
        "https://www.linkedin.com/in/lylehmann/",
        "https://github.com/lylehmann",
      ],
      email: email,
    },
  }}
/>

<Schema
  item={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://lylehmann.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Portfolio",
        item: "https://lylehmann.com/blog",
      },
    ],
  }}
/>

<Layout>
  <!-- Header Widget ***************** -->
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '/' },
        { text: 'Porfolio', href: '/blog' },
        { text: 'About', href: '/about' },
        { text: 'Resume', href: '/resume' },
      ]}
      actions={[
        {
          text: 'Meet me',
          href: `https://calendly.com/lylehmann`,
          target: '_blank',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Blog List ***************** -->
  <section class="relative max-w-4xl px-6 py-12 mx-auto sm:px-6 sm:py-16 lg:py-20">
    <Headline subtitle="Explore user-centered solutions that blend accessibility, creativity, and technology. Discover case studies showcasing inclusive UX design and digital innovation."> Portfolio <br> <span class="text-4xl font-semibold text-blue-600 dark:text-blue-300">Inclusive UX Design and Accessibility</span> </Headline>
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    <!--
      <PostTags tags={allCategories} class="mb-2" title="Search by Categories:" isCategory />
      <PostTags tags={allTags}  title="Search by Tags:" />
    -->
  </section>
</Layout>
