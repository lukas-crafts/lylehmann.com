---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import { Home } from 'lucide-astro';
---

<Layout title="404: Not Found">
  <Header slot="header" />

  <section class="min-h-screen flex items-center justify-center p-6 pt-32">
    <main class="max-w-3xl w-full text-center space-y-12">
      <div class="space-y-6">
        <div class="inline-block px-4 py-1.5 rounded-full border border-red-500/20 bg-red-500/10 text-xs font-bold tracking-wider uppercase text-red-400">
          Error 404
        </div>
        <h1 class="text-7xl font-black tracking-tighter sm:text-9xl bg-gradient-to-br from-white via-white to-zinc-600 bg-clip-text text-transparent">
          Lost in <br /> <span class="text-emerald-500">Space.</span>
        </h1>
        <p class="text-xl text-zinc-400 leading-relaxed max-w-xl mx-auto">
          The page you requested couldn't be found. It might have been moved, deleted, or never existed in the first place.
        </p>
      </div>
      
      <div class="flex justify-center">
        <a href="/" class="group flex items-center gap-3 px-8 py-4 rounded-2xl bg-emerald-500 text-zinc-950 font-black transition-all hover:scale-105 active:scale-95 hover:shadow-[0_0_30px_rgba(16,185,129,0.3)]">
          Back to Homepage
          <Home class="w-5 h-5 transition-transform group-hover:scale-110" />
        </a>
      </div>
    </main>
  </section>

  <Footer slot="footer" />
</Layout>
