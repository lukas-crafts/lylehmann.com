---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[
  { dark: theme === 'dark' },
  'relative z-10 border-t border-gray-200 dark:border-slate-800 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100',
  'motion-safe:opacity-100 !animate-none',
  'print:static print:opacity-100' // Ensure visibility in print mode
]}>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-12 motion-safe:opacity-100 !animate-none">
    <nav class="grid grid-cols-12 gap-4 sm:gap-8">
      <div class="col-span-12 lg:col-span-4">
        <div class="mb-2">
          <a class="inline-block text-xl font-bold" href={getHomePermalink()}>{SITE?.name}</a>
        </div>
        <div class="text-sm text-gray-600 dark:text-gray-400 flex gap-1">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? ' · ' : ''}
                <a
                  class="hover:text-gray-700 dark:hover:text-gray-300 transition duration-150 ease-in-out hover:underline"
                  href={href}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <div class="mb-2 font-medium dark:text-gray-300">{title}</div>
            {links && Array.isArray(links) && links.length > 0 && (
              <ul class="text-sm space-y-2">
                {links.map(({ text, href, ariaLabel }) => (
                  <li>
                    <a
                      class="text-gray-600 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition duration-150 ease-in-out hover:underline"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </nav>
    <div class="mt-8 md:flex md:items-center md:justify-between">
      <div class="flex space-x-4">
        {
          socialLinks?.map(({ ariaLabel, href, icon }) => (
            <a
              class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary rounded-lg p-2.5 transition duration-150 ease-in-out"
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={ariaLabel}
            >
              {icon && <Icon name={icon} class="w-5 h-5" />}
            </a>
          ))
        }
      </div>
      <div class="mt-4 md:mt-0 text-sm text-gray-600 dark:text-gray-400" set:html={footNote} />
    </div>
  </div>
</footer>
