---
const year = new Date().getFullYear();
---

<footer class="bg-zinc-950 border-t border-zinc-900 py-20 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
        <div class="col-span-1 md:col-span-2 space-y-6">
            <a href="/" class="text-2xl font-bold tracking-tighter flex items-center gap-2">
                <div class="w-10 h-10 rounded-xl bg-emerald-500 flex items-center justify-center text-zinc-950 font-black">
                    L
                </div>
                lylehmann.com
            </a>
            <p class="text-zinc-400 max-w-sm leading-relaxed">
                Expert UX Designer and Accessibility Advocate. Building digital solutions that empower every user, regardless of ability.
            </p>
        </div>

        <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-zinc-500 mb-6">Explore</h3>
            <ul class="space-y-4">
                <li><a href="/portfolio" class="text-zinc-400 hover:text-emerald-400 transition-colors">Portfolio</a></li>
                <li><a href="/services" class="text-zinc-400 hover:text-emerald-400 transition-colors">Services</a></li>
                <li><a href="/about" class="text-zinc-400 hover:text-emerald-400 transition-colors">About</a></li>
                <li><a href="/contact" class="text-zinc-400 hover:text-emerald-400 transition-colors">Contact</a></li>
            </ul>
        </div>

        <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-zinc-500 mb-6">Social</h3>
            <ul class="space-y-4">
                <li><a href="https://linkedin.com/in/lylehmann" class="text-zinc-400 hover:text-emerald-400 transition-colors">LinkedIn</a></li>
                <li><a href="https://github.com/lylehmann" class="text-zinc-400 hover:text-emerald-400 transition-colors">GitHub</a></li>
                <li><a href="mailto:lylehmann@gmail.com" class="text-zinc-400 hover:text-emerald-400 transition-colors">Email</a></li>
            </ul>
        </div>
    </div>

    <div class="max-w-7xl mx-auto mt-20">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8 pt-12 border-t border-zinc-800">
        <div class="text-zinc-500 text-sm">
          © {year} Lukas Yair Lehmann. All rights reserved.
        </div>
        <div class="flex gap-8">
          <a href="/impressum" class="text-zinc-500 hover:text-white transition-colors text-sm">Impressum</a>
          <a href="/privacy" class="text-zinc-500 hover:text-white transition-colors text-sm">Privacy Policy</a>
        </div>
      </div>
    </div>
</footer>
