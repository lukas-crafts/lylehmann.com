---
// This is a Server Island that fetches real GitHub status (mocked for now)
// server:defer ensures it doesn't block the main page load

// In a real app, you'd use:
// const res = await fetch('https://api.github.com/users/lylehmann/events/public');
// const data = await res.json();

// Mocking some dynamic data
const lastCommit = {
  repo: "lylehmann.com",
  message: "feat: implement astro 6 island architecture",
  time: "2 mins ago",
};

// Simulate API delay
await new Promise((resolve) => setTimeout(resolve, 600));
---

<div class="flex items-center gap-3 p-4 rounded-2xl bg-zinc-900/50 border border-zinc-800 text-xs animate-in fade-in slide-in-from-bottom-2 duration-700">
    <div class="w-8 h-8 rounded-lg bg-zinc-800 flex items-center justify-center text-zinc-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
    </div>
    <div class="space-y-1 overflow-hidden">
        <div class="font-bold text-zinc-300 flex items-center gap-2">
            Latest commit to <span class="text-emerald-500">{lastCommit.repo}</span>
        </div>
        <div class="text-zinc-500 truncate italic">"{lastCommit.message}"</div>
        <div class="text-[10px] text-zinc-600 font-bold uppercase tracking-widest">{lastCommit.time}</div>
    </div>
</div>
