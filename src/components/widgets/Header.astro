---
import { getCollection } from "astro:content";
import { Menu, X } from "lucide-astro";
import Search from "./Search";

const links = [
  { text: "Portfolio", href: "/portfolio" },
  { text: "Archive", href: "/archive" },
  { text: "Services", href: "/services" },
  { text: "About", href: "/about" },
];

const projects = await getCollection("portfolio", ({ data }) => !data.draft);
const searchItems = projects.map((p) => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  category: p.data.category ?? "",
  tags: p.data.tags ?? [],
  tools: p.data.tools ?? [],
}));
---

<header class="fixed top-0 w-full z-50 transition-all duration-300 border-b border-transparent data-[scrolled=true]:bg-zinc-950/80 data-[scrolled=true]:backdrop-blur-xl data-[scrolled=true]:border-zinc-800" id="main-header">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tighter group flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center text-zinc-950 transition-transform group-hover:rotate-12">
                L
            </div>
            <span class="group-hover:text-emerald-400 transition-colors">lylehmann</span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-8">
            <Search items={searchItems} client:only="preact" />
            {links.map(link => (
                <a href={link.href} class="text-sm font-medium text-zinc-400 hover:text-white transition-colors relative group">
                    {link.text}
                    <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-emerald-500 transition-all group-hover:w-full"></span>
                </a>
            ))}
            <a href="/contact" class="px-5 py-2 rounded-full bg-zinc-50 text-zinc-950 text-sm font-semibold hover:bg-white transition-all hover:ring-4 hover:ring-zinc-50/10 active:scale-95">
                Let's talk
            </a>
        </nav>

        <!-- Mobile Toggle -->
        <button
            class="md:hidden p-2 text-zinc-400 hover:text-white"
            id="mobile-menu-toggle"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
        >
            <Menu class="w-6 h-6" id="menu-icon" />
            <X class="w-6 h-6 hidden" id="close-icon" />
        </button>
    </div>

    <!-- Mobile Menu -->
    <div class="hidden md:hidden fixed inset-0 top-20 bg-zinc-950 z-40 p-6 space-y-8 animate-in fade-in slide-in-from-top-4" id="mobile-menu">
        <nav class="flex flex-col gap-6">
            {links.map(link => (
                <a href={link.href} class="text-2xl font-bold text-zinc-400 hover:text-emerald-400 transition-colors">
                    {link.text}
                </a>
            ))}
        </nav>
        <div class="pt-8 border-t border-zinc-800">
            <a href="/contact" class="block w-full text-center px-6 py-4 rounded-2xl bg-emerald-500 text-zinc-950 font-bold">
                Get in touch
            </a>
        </div>
    </div>
</header>

<script>
    const header = document.getElementById('main-header');
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    // Scroll effect
    window.addEventListener('scroll', () => {
        if (window.scrollY > 20) {
            header?.setAttribute('data-scrolled', 'true');
        } else {
            header?.setAttribute('data-scrolled', 'false');
        }
    });

    // Mobile menu toggle
    toggle?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden');
        menuIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
        document.body.style.overflow = isOpen ? 'auto' : 'hidden';

        // Update ARIA
        toggle.setAttribute('aria-expanded', String(!isOpen));
    });
</script>
