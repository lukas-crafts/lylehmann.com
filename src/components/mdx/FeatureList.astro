---
interface Item {
  title: string;
  description: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props as Props;
---
<div class="@container grid @sm:grid-cols-2 gap-4 my-12">
  {items.map((feature) => (
    <div class="group p-6 rounded-2xl border border-zinc-800 bg-zinc-900/30 hover:border-emerald-500/30 hover:bg-zinc-900/60 transition-all space-y-2">
      <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 mb-3" />
      <h3 class="text-lg font-bold text-zinc-100 mb-2 mt-0!">
        {feature.title}
      </h3>
      <p class="text-sm text-zinc-400 leading-relaxed mb-0!">
        {feature.description}
      </p>
    </div>
  ))}
</div>
