---
interface Item {
  title: string;
  description: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props as Props;
---
<div class="space-y-0 my-12">
  {items.map((step, index) => (
    <div class="flex gap-5 group">
      <div class="flex flex-col items-center shrink-0">
        <div class="w-7 h-7 rounded-full border-2 border-emerald-500 bg-zinc-950 text-emerald-400 flex items-center justify-center font-black text-xs mt-1">
          {index + 1}
        </div>
        {index !== items.length - 1 && (
          <div class="w-px grow bg-zinc-800 my-1" />
        )}
      </div>
      <div class="pb-8 pt-0.5 min-w-0">
        <h3 class="text-base font-bold text-zinc-100 mb-1 mt-0!">
          {step.title}
        </h3>
        <p class="text-sm text-zinc-400 leading-relaxed mb-0!">
          {step.description}
        </p>
      </div>
    </div>
  ))}
</div>
