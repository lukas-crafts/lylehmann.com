---
import { twMerge } from "tailwind-merge";
import type { ItemGrid as Props } from "../../types";
import { sanitize } from "../../utils/sanitize";
import Button from "./Button.astro";
import Icon from "./Icon.astro";

const { items = [], columns, defaultIcon = "", classes = {} } = Astro.props;

const {
  container: containerClass = "",
  // container: containerClass = "sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
  panel: panelClass = "",
  title: titleClass = "",
  description: descriptionClass = "",
  icon: defaultIconClass = "text-primary",
} = classes;
---

{
  items && (
    <div
      class={twMerge(
        `grid gap-4 gap-x-6 sm:gap-y-4 ${
          columns === 4
            ? 'lg:grid-cols-4 md:grid-cols-2 sm:grid-cols-2'
            : columns === 3
              ? 'lg:grid-cols-3 sm:grid-cols-2'
              : columns === 2
                ? 'sm:grid-cols-2 '
                : ''
        }`,
        containerClass
      )}
    >
      {items.map(({ title, description, icon, callToAction, classes: itemClasses = {} }) => (
        <div
          class={twMerge(
            'relative flex flex-col items-center motion-safe:md:opacity-0 p-0 text-center motion-safe:md:intersect:animate-fade intersect-once intersect-quarter intercept-no-queue',
            panelClass,
            itemClasses?.panel
          )}
        >
          {(icon || defaultIcon) && (
            <Icon name={icon || defaultIcon} class={twMerge('mb-2 w-10 h-10', defaultIconClass, itemClasses?.icon)} />
          )}
          <div class={twMerge('font-bold text-xl', titleClass, itemClasses?.title)}>{title}</div>
          {description && (
            <p
              class={twMerge('mt-1 text-muted text-base', descriptionClass, itemClasses?.description)}
              set:html={sanitize(description)}
            />
          )}
          {callToAction && (
            <div class="mt-1">
              <Button {...(callToAction as any)} />
            </div>
          )}
        </div>
      ))}
    </div>
  )
}
