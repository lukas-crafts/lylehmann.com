---
import {
  Accessibility,
  Apple,
  ArrowLeft,
  ArrowRight,
  Bell,
  Blocks,
  Calendar,
  ChevronLeft,
  ChevronRight,
  Clock,
  Cloud,
  Diamond,
  ExternalLink,
  Facebook,
  Github,
  Globe,
  Grid3x3,
  Heart,
  Inbox,
  Layout,
  Lightbulb,
  Linkedin,
  Mail,
  MapPin,
  Megaphone,
  Menu,
  MessageCircle,
  Moon,
  Music,
  Palette,
  Pencil,
  Phone,
  Plug,
  Rocket,
  Scale,
  Search,
  Settings,
  Smartphone,
  Sparkles,
  Sun,
  Tag,
  Timer,
  Twitter,
  User,
  Users,
  X,
  ZoomIn,
} from "lucide-astro";
import { twMerge } from "tailwind-merge";
import type { ItemGrid as Props } from "../../types";
import { sanitize } from "../../utils/sanitize";
import Button from "./Button.astro";
import Icon from "./Icon.astro";

const { items = [], columns, defaultIcon = "", classes = {} } = Astro.props;

const {
  container: containerClass = "",
  panel: panelClass = "",
  title: titleClass = "",
  description: descriptionClass = "",
  icon: defaultIconClass = "text-primary",
  action: actionClass = "",
} = classes;
---

{
  items && (
    <div
      class={twMerge(
        `grid mx-auto gap-8 md:gap-y-12 ${
          columns === 4
            ? 'lg:grid-cols-4 md:grid-cols-3 sm:grid-cols-2'
            : columns === 3
              ? 'lg:grid-cols-3 sm:grid-cols-2'
              : columns === 2
                ? 'sm:grid-cols-2 '
                : ''
        }`,
        containerClass
      )}
    >
      {items.map(({ title, description, icon, callToAction, tags, classes: itemClasses = {} }) => (
        <div class="motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade intersect-once">
          <div class={twMerge('flex flex-row max-w-md', panelClass, itemClasses?.panel)}>
            <div class="flex justify-center">
              {(icon || defaultIcon) && (
                <Icon
                  name={icon || defaultIcon}
                  class={twMerge('mr-2 rtl:mr-0 rtl:ml-2 w-7 h-7', defaultIconClass, itemClasses?.icon)}
                />
              )}
            </div>
            <div class="mt-0.5">
              {title && <h3 class={twMerge('font-bold text-xl', titleClass, itemClasses?.title)}>{title}</h3>}
              {description && (
                <p
                  class={twMerge(`${title ? 'mt-3' : ''} text-muted`, descriptionClass, itemClasses?.description)}
                  set:html={sanitize(description)}
                />
              )}
              {tags && tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-2" aria-label="Skills and tools">
                  {tags.map((tag) => (
                    <span class="bg-[var(--color-interactive-secondary-hover)] px-2 py-0.5 border border-[var(--color-border-default)] rounded-full font-medium text-[var(--color-text-body)] text-xs">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
              {callToAction && (
                <div class={twMerge(`${title || description ? 'mt-3' : ''}`, actionClass, itemClasses?.actionClass)}>
                  <Button variant="link" {...callToAction} />
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  )
}
