---
import type { Timeline as Props } from "../../types";

const { items = [], classes = {}, defaultIcon } = Astro.props as Props;

const containerClass = (classes?.container as string) || "";
const panelClass = (classes?.panel as string) || "";
const titleClass = (classes?.title as string) || "";
const descriptionClass = (classes?.description as string) || "";
const defaultIconClass =
  (classes?.icon as string) ||
  "text-primary dark:text-slate-200 border-primary dark:border-blue-700";
---

{
  items && items.length && (
    <div class={containerClass}>
      {items.map(({ title, description, icon, date, classes: itemClasses = {} }, index = 0) => (
        <div
          class={twMerge(
            'flex intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade',
            panelClass,
            itemClasses?.panel
          )}
        >
          <div class="flex flex-col items-center mr-4 rtl:mr-0 rtl:ml-4">
            <div>
              <div class="flex items-center justify-center">
                {(icon || defaultIcon) && (
                  <Icon
                    name={(icon || defaultIcon) as string}
                    class={twMerge('w-10 h-10 p-2 rounded-full border-2', defaultIconClass, itemClasses?.icon)}
                  />
                )}
              </div>
            </div>
            {index !== items.length - 1 && <div class="w-px h-full bg-black/10 dark:bg-slate-400/50" />}
          </div>
          <div class={`pt-1 ${index !== items.length - 1 ? 'pb-8' : ''}`}>
            {date && (
              <time
                class="block text-xs font-semibold uppercase tracking-wider text-primary dark:text-blue-400 mb-1"
                datetime={date instanceof Date ? date.toISOString() : date}
              >
                {date instanceof Date ? getFormattedDate(date) : date}
              </time>
            )}
            {title && (
              <p class={twMerge('text-xl font-bold', titleClass, itemClasses?.title)} set:html={sanitize(title)} />
            )}
            {description && (
              <p
                class={twMerge('text-muted mt-2', descriptionClass, itemClasses?.description)}
                set:html={sanitize(description)}
              />
            )}
          </div>
        </div>
      ))}
    </div>
  )
}
