---
import { DarkMode, SkipLink } from "accessible-astro-components";
import {
  ArrowLeft,
  ArrowRight,
  Calendar,
  ChevronLeft,
  ChevronRight,
  Clock,
  ExternalLink,
  Facebook,
  Github,
  Linkedin,
  Mail,
  MapPin,
  Menu,
  Moon,
  Phone,
  Search,
  Sun,
  Tag,
  Twitter,
  User,
  X,
} from "lucide-astro";
import Navigation from "../components/Navigation.astro";

/**
 * Header Component
 *
 * @description A component that displays the header of the website
 */
---

<header>
  <SkipLink />
  <Navigation>
    <ul class="flex flex-row items-baseline gap-8">
      <li class="menu-item">
        <a href="/">Home</a>
      </li>
      <li class="menu-item">
        <a href="/portfolio">Portfolio</a>
      </li>
      <li class="menu-item">
        <a href="/about">About</a>
      </li>
    </ul>
  </Navigation>
</header>

<style lang="scss" is:global>
  header {
    .type-icon {
      display: block;
      margin-inline: -7px;

      svg {
        inline-size: 30px;
        block-size: 30px;
      }
    }
  }
</style>
