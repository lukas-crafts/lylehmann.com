---
import Navigation from "./Navigation.astro";

/**
 * Header Component
 *
 * @description A component that displays the header of the website
 */
---

<header>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-white px-4 py-2 rounded-md z-50"
    >Skip to content</a
  >
  <Navigation>
    <ul class="flex flex-row items-baseline gap-8">
      <li class="menu-item">
        <a href="/">Home</a>
      </li>
      <li class="menu-item">
        <a href="/portfolio">Portfolio</a>
      </li>
      <li class="menu-item">
        <a href="/about">About</a>
      </li>
    </ul>
  </Navigation>
</header>

<style lang="scss" is:global>
  header {
    .type-icon {
      display: block;
      margin-inline: -7px;

      svg {
        inline-size: 30px;
        block-size: 30px;
      }
    }
  }
</style>
