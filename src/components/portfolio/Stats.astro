---
interface Item {
  title: string;
  subtitle?: string;
}

interface Props {
  items: Item[];
}
const { items } = Astro.props as Props;
---
<div class="grid grid-cols-2 lg:grid-cols-4 rounded-2xl overflow-hidden border border-zinc-800 my-12 bg-zinc-900/20">
  {items.map((stat, i) => (
    <div 
      class={`flex flex-col items-center justify-center text-center p-6 sm:p-8 border-zinc-800
        ${i % 2 !== 0 ? 'border-l' : ''} 
        ${i >= 2 ? 'border-t lg:border-t-0' : ''}
        ${i % 4 !== 0 ? 'lg:border-l' : ''}
        ${i % 2 === 0 ? 'bg-zinc-900/60' : 'bg-zinc-900/30'}
      `}
    >
      <div class="text-3xl sm:text-4xl font-black tracking-tighter text-emerald-400 leading-none mb-2">
        {stat.title}
      </div>
      {stat.subtitle && (
        <div class="text-[10px] sm:text-xs text-zinc-500 font-black uppercase tracking-widest leading-tight">
          {stat.subtitle}
        </div>
      )}
    </div>
  ))}
</div>
