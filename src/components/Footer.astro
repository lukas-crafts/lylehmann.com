---
import CallToAction from "./CallToAction.astro";
import ExternalLink from "./ExternalLink.astro";
import Logo from "./Logo.astro";

/**
 * Footer Component
 *
 * @description A component that displays the footer of the website
 */
const currentYear = new Date().getFullYear();
---

<footer>
  <CallToAction />
  <section class="py-20">
    <h2 class="sr-only">Footer</h2>
    <div class="gap-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 container">
      <div class="flex flex-col gap-4">
        <h3 class="font-bold text-2xl">Navigation</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/portfolio">Portfolio</a></li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <h3 class="font-bold text-2xl">Transparency</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/privacy-policy">Privacy Policy</a></li>
          <li><a href="/impressum">Legal Disclosure (Impressum)</a></li>
          <li><a href="/about-this-site">About This Site</a></li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <h3 class="font-bold text-2xl">Let's Connect</h3>
        <ul class="flex flex-col gap-2">
          <li>
            <ExternalLink href="mailto:lukasyairlehmann@gmail.com">E-Mail</ExternalLink>
          </li>
          <li>
            <ExternalLink href="https://linkedin.com/in/lylehmann">LinkedIn</ExternalLink>
          </li>
          <li>
            <ExternalLink href="https://github.com/lylehmann">GitHub</ExternalLink>
          </li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Logo loading="lazy" />
        <p class="leading-[1.75]">
          Tip: Press <kbd>⌘</kbd> + <kbd>F5</kbd> to start VoiceOver or <kbd
            >Win</kbd
          >
          + <kbd>Ctrl</kbd> + <kbd>Enter</kbd> for Narrator.
        </p>
      </div>
    </div>
  </section>
  <section class="py-8">
    <div class="flex md:flex-row flex-col md:justify-between gap-4 container">
      <p>
        &copy; 2024-{currentYear} - Lukas Yair Lehmann
      </p>
      <p>✨ Built with <ExternalLink href="https://astro.build">Astro</ExternalLink> and the <ExternalLink href="https://github.com/incluud/accessible-astro-starter">Accessible Starter Theme</ExternalLink>.</p>
    </div>
  </section>
</footer>

<style>
  section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
