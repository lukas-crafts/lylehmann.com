---
import '@fontsource-variable/inter';

// Available Fonts
// 'DM Sans', 'Nunito', 'Dosis', 'Outfit', 'Roboto', 'Literata', 'IBM Plex Sans', 'Karla', 'Poppins', 'Fira Sans', 'Libre Franklin', 'Inconsolata', 'Raleway', 'Oswald', 'Space Grotesk', 'Urbanist'
---

<style is:inline>
  :root {
    /* Font Families */
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Primary Colors */
    --aw-color-primary: rgb(255, 87, 34); /* Deep Orange */
    --aw-color-secondary: rgb(63, 81, 181); /* Indigo */
    --aw-color-accent: rgb(255, 193, 7); /* Amber */

    /* Text Colors */
    --aw-color-text-heading: rgb(33, 33, 33); /* Dark Grey */
    --aw-color-text-default: rgb(66, 66, 66); /* Grey */
    --aw-color-text-muted: rgb(158, 158, 158); /* Light Grey */
    --aw-color-text-muted-light: rgb(189, 189, 189); /* Lighter Grey */
    --aw-color-text-muted-dark: rgb(117, 117, 117); /* Darker Grey */
    --aw-color-text-page: rgb(66, 66, 66); /* Grey */

    /* Background Colors */
    --aw-color-bg-page: rgb(255, 255, 255); /* White */
    --aw-color-bg-page-dark: rgb(48, 48, 48); /* Dark Grey */
    --aw-color-bg-custom-light: rgb(255, 235, 238); /* Light Pink */
    --aw-color-bg-custom-dark: rgb(69, 90, 100); /* Blue Grey */
    --aw-color-bg-neutral: rgb(224, 224, 224); /* Light Grey */
    --aw-color-bg-neutral-dark: rgb(97, 97, 97); /* Dark Grey */

    /* Background Assignments */
    --aw-bg-container: var(--aw-color-bg-page);
    --aw-bg-container-dark: var(--aw-color-bg-page-dark);
    --aw-bg-content: var(--aw-color-bg-custom-light);
    --aw-bg-content-dark: var(--aw-color-bg-custom-dark);
    --aw-steps-bg-image: var(--aw-color-bg-neutral);
    --aw-steps-bg-image-dark: var(--aw-color-bg-neutral-dark);
    --aw-content-bg-image: var(--aw-color-bg-neutral);

    /* Component Colors */
    --aw-color-button-bg: rgb(255, 87, 34); /* Deep Orange */
    --aw-color-button-bg-hover: rgb(230, 74, 25); /* Darker Deep Orange */
    --aw-color-button-text: rgb(255, 255, 255); /* White */
    --aw-color-link: rgb(63, 81, 181); /* Indigo */
    --aw-color-link-hover: rgb(48, 63, 159); /* Darker Indigo */
    --aw-color-icon: rgb(33, 33, 33); /* Dark Grey */
    --aw-color-icon-hover: rgb(255, 193, 7); /* Amber */
    --aw-color-svg-icon-fill: rgb(33, 33, 33); /* Dark Grey */
    --aw-color-svg-icon-stroke: rgb(255, 193, 7); /* Amber */

    /* Button Colors */
    --aw-color-button-primary-bg: var(--aw-color-primary);
    --aw-color-button-primary-bg-hover: hsl(14, 100%, 50%); /* Darker Deep Orange */
    --aw-color-button-primary-text: hsl(0, 0%, 100%); /* White */
    --aw-color-button-primary-text-hover: hsl(0, 0%, 90%); /* Light Grey */

    --aw-color-button-secondary-bg: transparent;
    --aw-color-button-secondary-bg-hover: hsl(0, 0%, 88%); /* Light Grey */
    --aw-color-button-secondary-text: hsl(0, 0%, 26%); /* Grey */
    --aw-color-button-secondary-text-hover: hsl(0, 0%, 38%); /* Dark Grey */
    --aw-color-button-secondary-border: hsl(0, 0%, 26%); /* Grey */

    --aw-color-button-tertiary-bg: transparent;
    --aw-color-button-tertiary-bg-hover: transparent;
    --aw-color-button-tertiary-text: hsl(0, 0%, 62%); /* Light Grey */
    --aw-color-button-tertiary-text-hover: hsl(0, 0%, 26%); /* Grey */

    /* Selection Colors */
    ::selection {
      background-color: rgb(255, 193, 7); /* Amber */
    }
  }

  .dark {
    /* Font Families */
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Primary Colors */
    --aw-color-primary: rgb(255, 87, 34); /* Deep Orange */
    --aw-color-secondary: rgb(63, 81, 181); /* Indigo */
    --aw-color-accent: rgb(255, 193, 7); /* Amber */

    /* Text Colors */
    --aw-color-text-heading: rgb(255, 255, 255); /* White */
    --aw-color-text-default: rgb(224, 224, 224); /* Light Grey */
    --aw-color-text-muted: rgb(189, 189, 189); /* Lighter Grey */
    --aw-color-text-muted-light: rgb(158, 158, 158); /* Light Grey */
    --aw-color-text-muted-dark: rgb(117, 117, 117); /* Darker Grey */
    --aw-color-text-page: rgb(224, 224, 224); /* Light Grey */

    /* Background Colors */
    --aw-color-bg-page: rgb(33, 33, 33); /* Dark Grey */
    --aw-color-bg-custom-light: rgb(255, 235, 238); /* Light Pink */
    --aw-color-bg-custom-dark: rgb(69, 90, 100); /* Blue Grey */
    --aw-color-bg-neutral: rgb(224, 224, 224); /* Light Grey */
    --aw-color-bg-neutral-dark: rgb(97, 97, 97); /* Dark Grey */

    /* Background Assignments */
    --aw-bg-container: var(--aw-color-bg-page);
    --aw-bg-container-dark: var(--aw-color-bg-page-dark);
    --aw-bg-content: var(--aw-color-bg-custom-light);
    --aw-bg-content-dark: var(--aw-color-bg-custom-dark);
    --aw-steps-bg-image: var(--aw-color-bg-neutral);
    --aw-steps-bg-image-dark: var(--aw-color-bg-neutral-dark);
    --aw-content-bg-image: var(--aw-color-bg-neutral);

    /* Component Colors */
    --aw-color-button-bg: rgb(255, 87, 34); /* Deep Orange */
    --aw-color-button-bg-hover: rgb(230, 74, 25); /* Darker Deep Orange */
    --aw-color-button-text: rgb(255, 255, 255); /* White */
    --aw-color-link: rgb(63, 81, 181); /* Indigo */
    --aw-color-link-hover: rgb(48, 63, 159); /* Darker Indigo */
    --aw-color-icon: rgb(255, 255, 255); /* White */
    --aw-color-icon-hover: rgb(255, 193, 7); /* Amber */
    --aw-color-svg-icon-fill: rgb(255, 255, 255); /* White */
    --aw-color-svg-icon-stroke: rgb(255, 193, 7); /* Amber */

    /* Button Colors */
    --aw-color-button-primary-bg: var(--aw-color-primary);
    --aw-color-button-primary-bg-hover: hsl(14, 100%, 50%); /* Darker Deep Orange */
    --aw-color-button-primary-text: hsl(0, 0%, 100%); /* White */
    --aw-color-button-primary-text-hover: hsl(0, 0%, 90%); /* Light Grey */

    --aw-color-button-secondary-bg: transparent;
    --aw-color-button-secondary-bg-hover: hsl(0, 0%, 38%); /* Dark Grey */
    --aw-color-button-secondary-text: hsl(0, 0%, 88%); /* Light Grey */
    --aw-color-button-secondary-text-hover: hsl(0, 0%, 100%); /* White */
    --aw-color-button-secondary-border: hsl(0, 0%, 88%); /* Light Grey */

    --aw-color-button-tertiary-bg: transparent;
    --aw-color-button-tertiary-bg-hover: transparent;
    --aw-color-button-tertiary-text: hsl(0, 0%, 74%); /* Light Grey */
    --aw-color-button-tertiary-text-hover: hsl(0, 0%, 88%); /* Light Grey */

    /* Selection Colors */
    ::selection {
      background-color: rgb(255, 193, 7); /* Amber */
      color: rgb(33, 33, 33); /* Dark Grey */
    }
  }
</style>
