---
import "~/assets/styles/global.css";
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  metadata?: any;
}

const { 
  title = "Lukas Yair Lehmann | UX & Accessibility",
  description = "Building inclusive digital experiences through accessible design and high-performance engineering.",
  metadata = {}
} = Astro.props;

const finalTitle = metadata.title || title;
const finalDescription = metadata.description || description;
const { canonical, robots, openGraph, twitter } = metadata;
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta name="generator" content={import.meta.env.GENERATOR} />
    <ClientRouter />
    
    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    
    {robots && (
      <meta name="robots" content={`${robots.index ? 'index' : 'noindex'}, ${robots.follow ? 'follow' : 'nofollow'}`} />
    )}
    
    <!-- Open Graph -->
    <meta property="og:title" content={openGraph?.title || finalTitle} />
    <meta property="og:description" content={openGraph?.description || finalDescription} />
    <meta property="og:type" content={openGraph?.type || "website"} />
    <meta property="og:url" content={openGraph?.url} />
    <meta property="og:site_name" content={openGraph?.siteName || "lylehmann.com"} />
    {openGraph?.images?.map((img: any) => (
      <>
        <meta property="og:image" content={img.url} />
        {img.width && <meta property="og:image:width" content={img.width.toString()} />}
        {img.height && <meta property="og:image:height" content={img.height.toString()} />}
      </>
    ))}
    
    <!-- Twitter -->
    <meta name="twitter:card" content={twitter?.cardType || "summary_large_image"} />
    <meta name="twitter:site" content={twitter?.site} />
    <meta name="twitter:creator" content={twitter?.handle} />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
</head>
<body class="bg-zinc-950 text-zinc-50 antialiased flex flex-col min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-emerald-500 focus:text-zinc-950 focus:rounded-md focus:font-bold">
        Skip to content
    </a>

    <slot name="header" />
    
    <main id="main-content" class="grow">
        <slot />
    </main>

    <slot name="footer" />
</body>
</html>
