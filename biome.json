{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "src/**/*.{js,ts,tsx,jsx,json}",
      "*.{js,ts,tsx,jsx,json}",
      "!!src/**/*.astro",
      "!!dist/**",
      "!!.astro/**",
      "!!**/.cache/**",
      "!!**/trunk/**",
      "!!vendor/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "linter": {
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
