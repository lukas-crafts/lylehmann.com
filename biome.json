{
  "$schema": "https://biomejs.dev/schemas/1.5.3/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsoleLog": "warn"
      },
      "style": {
        "useTemplate": "error",
        "useShorthandArrayType": "error",
        "useNodejsImportProtocol": {
          "level": "error",
          "options": {
            "ignore": ["astro.config.ts"]
          }
        }
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "formatWithErrors": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingComma": "es5",
      "semicolons": "always"
    }
  },
  "files": {
    "include": ["src/**/*.{js,ts,jsx,tsx,astro}", "*.{js,ts,mjs,cjs}"],
    "ignore": ["node_modules", "dist", ".astro", "*.d.ts"]
  }
}
